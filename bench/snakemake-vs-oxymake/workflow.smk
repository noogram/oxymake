rule all:
    input:
        "merged.txt"

# Layer 0 — seed (single shell rule).
rule seed:
    output:
        "seed.txt"
    shell:
        "printf 'seed\n' > {output}"

# Layer 1 — shell rule (per item).
rule gen:
    input:
        "seed.txt"
    output:
        "step1/{item}.txt"
    shell:
        "printf '%s\n' {wildcards.item} > {output}"

# Layer 2 — Python-via-shell rule (per item).
# bench_lib.py is declared as a named input so editing it correctly
# invalidates the cache (a tool the job reads IS a dependency).
rule process:
    input:
        data="step1/{item}.txt",
        lib="bench_lib.py"
    output:
        "step2/{item}.txt"
    shell:
        "python3 {input.lib} {input.data} {output}"

# Layer 3 — file-only / cp rule (per item).
rule finalize:
    input:
        "step2/{item}.txt"
    output:
        "step3/{item}.txt"
    shell:
        "cp {input} {output}"

# Merge (single).
rule merge:
    input:
        expand("step3/{item}.txt", item=ITEMS)
    output:
        "merged.txt"
    shell:
        "cat {input} > {output}"

# CSV ETL pipeline — download, clean, aggregate, report
# Exercises: Python-style variable, named I/O, expand with literals, params
#
# Pipeline:
#   1. Generate mock CSV sources
#   2. Clean/validate each source
#   3. Aggregate across sources
#   4. Generate summary statistics

SOURCES = ["sales", "inventory", "returns"]
REGIONS = ["north", "south", "east", "west"]

rule all:
    input:
        "output/summary_report.txt",
        "output/region_breakdown.txt"

rule generate_source:
    output:
        csv="raw/{source}.csv"
    params:
        n_rows=200
    shell:
        """
        echo "date,region,product,quantity,price" > {output.csv}
        for i in $(seq 1 {params.n_rows}); do
            day=$((i % 28 + 1))
            region=$(echo "north south east west" | tr ' ' '\n' | awk -v s=$i 'NR==s%4+1')
            product=$(echo "widget gadget doohickey thingamajig" | tr ' ' '\n' | awk -v s=$((i*7)) 'NR==s%4+1')
            qty=$((RANDOM % 100 + 1))
            price=$((RANDOM % 50 + 10))
            echo "2024-01-${{day}},$region,$product,$qty,$price" >> {output.csv}
        done
        """

rule clean_source:
    input:
        csv="raw/{source}.csv"
    output:
        csv="cleaned/{source}.csv",
        report="cleaned/{source}_validation.txt"
    log:
        "logs/clean_{source}.log"
    shell:
        """
        echo "Cleaning {wildcards.source}" > {log}
        # Remove any rows with missing fields
        head -1 {input.csv} > {output.csv}
        tail -n +2 {input.csv} | awk -F',' 'NF==5 && $4>0 && $5>0' >> {output.csv}
        total=$(tail -n +2 {input.csv} | wc -l | tr -d ' ')
        kept=$(tail -n +2 {output.csv} | wc -l | tr -d ' ')
        echo "Source: {wildcards.source}" > {output.report}
        echo "Total rows: $total" >> {output.report}
        echo "Valid rows: $kept" >> {output.report}
        echo "Dropped: $((total - kept))" >> {output.report}
        echo "Cleaned $kept/$total rows" >> {log}
        """

rule aggregate:
    input:
        csvs=expand("cleaned/{source}.csv", source=SOURCES)
    output:
        combined="output/combined.csv"
    log:
        "logs/aggregate.log"
    shell:
        """
        echo "Aggregating sources: {input.csvs}" > {log}
        head -1 $(echo {input.csvs} | tr ' ' '\n' | head -1) > {output.combined}
        for f in {input.csvs}; do
            source=$(basename "$f" .csv)
            tail -n +2 "$f" | awk -v s="$source" -F',' '{{ print $0 "," s }}' >> {output.combined}
        done
        echo "Combined: $(wc -l < {output.combined}) rows" >> {log}
        """

rule summary_stats:
    input:
        csv="output/combined.csv"
    output:
        "output/summary_report.txt"
    shell:
        """
        echo "=== Summary Report ===" > {output}
        echo "" >> {output}
        echo "Total records: $(tail -n +2 {input.csv} | wc -l | tr -d ' ')" >> {output}
        echo "" >> {output}
        echo "Revenue by product:" >> {output}
        tail -n +2 {input.csv} | awk -F',' '{{ rev[$3]+=$4*$5 }} END {{ for(p in rev) printf "  %s: $%d\\n", p, rev[p] }}' | sort >> {output}
        echo "" >> {output}
        echo "Total quantity: $(tail -n +2 {input.csv} | awk -F',' '{{ s+=$4 }} END {{ print s }}')" >> {output}
        """

rule region_breakdown:
    input:
        csv="output/combined.csv"
    output:
        "output/region_breakdown.txt"
    shell:
        """
        echo "=== Region Breakdown ===" > {output}
        echo "" >> {output}
        tail -n +2 {input.csv} | awk -F',' '
        {{ rev[$2]+=$4*$5; qty[$2]+=$4; cnt[$2]++ }}
        END {{
            for(r in rev) printf "%s: %d orders, %d units, $%d revenue\\n", r, cnt[r], qty[r], rev[r]
        }}' | sort >> {output}
        """
